---
const WA_LINK = "https://wa.me/573105164565?text=Hola%20quiero%20m%C3%A1s%20informaci%C3%B3n%20y%20agendar%20un%20servicio";
---

<section id="contacto" class="py-28 px-4 bg-charcoal relative overflow-hidden">
  <div class="absolute left-[-200px] top-1/2 -translate-y-1/2 w-[500px] h-[500px] rounded-full pointer-events-none"
       style="background: radial-gradient(circle, rgba(201,168,76,0.05) 0%, transparent 70%);">
  </div>

  <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-24 items-start">

    <!-- Left: info + map -->
    <div>
      <p class="text-gold text-xs tracking-[0.4em] uppercase mb-3">Encuéntranos</p>
      <h2 class="font-cormorant font-light text-soft leading-tight mb-6" style="font-size: clamp(2.2rem, 5vw, 3.8rem);">
        Agenda tu <em class="text-gold">cita</em><br>hoy mismo
      </h2>
      <div class="w-12 h-px bg-gold mb-10"></div>

      <div class="flex flex-col gap-8 mb-10">
        <!-- Address -->
        <div class="flex items-start gap-5">
          <div class="w-11 h-11 border border-[rgba(201,168,76,0.3)] flex items-center justify-center text-gold text-lg flex-shrink-0">📍</div>
          <div>
            <strong class="block text-gold text-xs tracking-widest uppercase mb-1">Ubicación</strong>
            <p class="text-soft/65 text-sm leading-relaxed">Cra 7A No 26-74 Local No 2<br/>Girardot, Colombia</p>
          </div>
        </div>

        <!-- Phone -->
        <div class="flex items-start gap-5">
          <div class="w-11 h-11 border border-[rgba(201,168,76,0.3)] flex items-center justify-center text-gold text-lg flex-shrink-0">📞</div>
          <div>
            <strong class="block text-gold text-xs tracking-widest uppercase mb-1">WhatsApp</strong>
            <p class="text-soft/65 text-sm">310 516 4565</p>
          </div>
        </div>

        <!-- Social -->
        <div class="flex items-start gap-5">
          <div class="w-11 h-11 border border-[rgba(201,168,76,0.3)] flex items-center justify-center text-gold text-lg flex-shrink-0">📱</div>
          <div>
            <strong class="block text-gold text-xs tracking-widest uppercase mb-1">Redes sociales</strong>
            <p class="text-soft/65 text-sm mb-3">@spadebeautycenter</p>
            <div class="flex gap-3">
              <a href="https://www.facebook.com/Spadebeautycenteroficial" target="_blank"
                 class="w-11 h-11 border border-[rgba(201,168,76,0.25)] flex items-center justify-center text-soft/50 no-underline hover:border-gold hover:text-gold hover:bg-[rgba(201,168,76,0.05)] transition-all">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
              </a>
              <a href="https://www.instagram.com/spadebeautycenter/" target="_blank"
                 class="w-11 h-11 border border-[rgba(201,168,76,0.25)] flex items-center justify-center text-soft/50 no-underline hover:border-gold hover:text-gold hover:bg-[rgba(201,168,76,0.05)] transition-all">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Google Maps -->
      <div class="border border-[rgba(201,168,76,0.2)] overflow-hidden">
        <iframe
          src="https://www.google.com/maps?q=Cra+7A+No+26-74+Local+No+2,+Girardot,+Colombia&output=embed"
          width="100%" height="280" style="border:0; display:block; filter:grayscale(0.3) contrast(1.1);"
          allowfullscreen loading="lazy" referrerpolicy="no-referrer-when-downgrade">
        </iframe>
      </div>
    </div>

    <!-- Right: CTA box -->
    <div class="bg-dark border border-[rgba(201,168,76,0.15)] p-12 flex flex-col gap-6">
      <h3 class="font-cormorant text-3xl font-light text-soft leading-tight">
        ¿Lista para tu<br>próxima cita?
      </h3>
      <p class="text-soft/55 text-sm leading-loose">
        Escríbenos por WhatsApp y con gusto te asesoramos sobre el servicio ideal para ti. Agendamos tu cita rápido y fácil.
      </p>
      <a href={WA_LINK} target="_blank"
         class="flex items-center justify-center gap-3 bg-[#25D366] text-white px-8 py-4 text-xs tracking-widest uppercase font-semibold font-montserrat no-underline hover:bg-[#1ebe5a] hover:-translate-y-0.5 hover:shadow-[0_8px_30px_rgba(37,211,102,0.3)] transition-all w-full">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
        </svg>
        Escribir por WhatsApp
      </a>
      <p class="text-soft/30 text-xs text-center">También puedes llamarnos al 310 516 4565</p>
    </div>

  </div>
</section>
