---

<section id="servicios" class="py-28 px-4 bg-dark">
  <div class="max-w-6xl mx-auto">

    <!-- Header -->
    <div class="text-center mb-20">
      <p class="text-gold text-xs tracking-[0.4em] uppercase mb-3">Lo que hacemos</p>
      <h2 class="font-cormorant font-light text-soft leading-tight" style="font-size: clamp(2.2rem, 5vw, 3.8rem);">
        Nuestros <em class="text-gold">servicios</em>
      </h2>
      <div class="w-12 h-px bg-gold mx-auto mt-6"></div>
    </div>

    <!-- Category tabs -->
    <div class="flex border border-[rgba(201,168,76,0.2)] w-fit mx-auto mb-14">
      <button id="btn-unas" onclick="showCat('unas')"
              class="cat-btn active px-10 py-3.5 text-xs tracking-widest uppercase font-medium font-montserrat border-r border-[rgba(201,168,76,0.2)] cursor-pointer transition-all bg-gold text-dark">
        ♠ Uñas
      </button>
      <button id="btn-pestanas" onclick="showCat('pestanas')"
              class="cat-btn px-10 py-3.5 text-xs tracking-widest uppercase font-medium font-montserrat cursor-pointer transition-all bg-transparent text-soft/50 hover:bg-gold hover:text-dark">
        ♠ Pestañas
      </button>
    </div>

    <!-- Uñas grid -->
    <div id="panel-unas" class="grid md:grid-cols-2 lg:grid-cols-3 gap-px">
      {unas.map(s => <ServiceCard {...s} />)}
    </div>

    <!-- Pestañas grid -->
    <div id="panel-pestanas" class="hidden grid md:grid-cols-2 lg:grid-cols-3 gap-px">
      {pestanas.map(s => <ServiceCard {...s} />)}

      <!-- Care note -->
      <div class="col-span-full bg-[rgba(201,168,76,0.04)] border border-[rgba(201,168,76,0.2)] p-8">
        <p class="text-gold text-xs tracking-widest uppercase mb-4">Cuidados y recomendaciones — Todas las pestañas</p>
        <div class="grid sm:grid-cols-3 gap-6">
          {[
            { icon: '💧', text: 'Evita mojarlas durante las primeras 24 horas' },
            { icon: '🚫', text: 'No uses rímel ni rizador' },
            { icon: '🪮', text: 'Limpia las pestañas con un cepillo suave' },
          ].map(c => (
            <div class="flex items-start gap-3">
              <span class="text-xl">{c.icon}</span>
              <p class="text-soft/60 text-xs leading-relaxed">{c.text}</p>
            </div>
          ))}
        </div>
      </div>
    </div>

  </div>
</section>

<script>
  function showCat(cat: string) {
    const panels = ['unas', 'pestanas'];
    panels.forEach(p => {
      const panel = document.getElementById(`panel-${p}`);
      const btn   = document.getElementById(`btn-${p}`);
      if (p === cat) {
        panel?.classList.remove('hidden');
        btn?.classList.add('bg-gold', 'text-dark');
        btn?.classList.remove('bg-transparent', 'text-soft/50');
      } else {
        panel?.classList.add('hidden');
        btn?.classList.remove('bg-gold', 'text-dark');
        btn?.classList.add('bg-transparent', 'text-soft/50');
      }
    });
  }
  (window as any).showCat = showCat;
</script>
