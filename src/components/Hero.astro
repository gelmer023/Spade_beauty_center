---
const WA_LINK = "https://wa.me/573105164565?text=Hola%20quiero%20m%C3%A1s%20informaci%C3%B3n%20y%20agendar%20un%20servicio";
---

<section id="hero" class="min-h-screen flex items-center justify-center relative overflow-hidden pt-32 pb-16 px-4">
  <!-- Background glow -->
  <div class="absolute inset-0 pointer-events-none"
       style="background: radial-gradient(ellipse 80% 60% at 50% 60%, rgba(201,168,76,0.08) 0%, transparent 70%), radial-gradient(ellipse 40% 40% at 80% 20%, rgba(201,168,76,0.05) 0%, transparent 60%);">
  </div>

  <!-- Rotating ring -->
  <div class="hero-circle" style="transform: translate(-50%, -50%);"></div>

  <!-- Content -->
  <div class="text-center relative z-10">
    <p class="animate-fade-up-1 text-gold text-xs tracking-[0.35em] uppercase mb-6">Girardot, Colombia</p>

    <svg class="animate-fade-up-2 w-20 h-20 mx-auto mb-6 drop-shadow-[0_0_30px_rgba(201,168,76,0.4)]"
         viewBox="0 0 100 85" xmlns="http://www.w3.org/2000/svg">
      <path d="M50 0 C50 0 10 28 10 50 C10 64 20 70 34 66 C28 74 25 82 20 85 L80 85 C75 82 72 74 66 66 C80 70 90 64 90 50 C90 28 50 0 50 0Z"
            fill="url(#heroGold)"/>
      <defs>
        <linearGradient id="heroGold" x1="10" y1="0" x2="90" y2="85" gradientUnits="userSpaceOnUse">
          <stop offset="0%" stop-color="#E2C97E"/>
          <stop offset="50%" stop-color="#C9A84C"/>
          <stop offset="100%" stop-color="#9A7A2E"/>
        </linearGradient>
      </defs>
    </svg>

    <h1 class="animate-fade-up-3 font-cormorant font-light text-soft leading-none tracking-wide uppercase"
        style="font-size: clamp(3.5rem, 9vw, 7rem);">
      Spade<br><em class="text-gold not-italic font-light">Beauty</em><br>Center
    </h1>

    <p class="animate-fade-up-4 text-xs tracking-[0.3em] uppercase text-soft/50 mt-6">
      Keratinas · Uñas · Pestañas y más
    </p>
    <p class="animate-fade-up-5 font-cormorant italic text-lg text-soft/60 mt-2">
      Donde cada detalle te hace brillar
    </p>

    <div class="animate-fade-up-6 w-14 h-px bg-gradient-to-r from-transparent via-gold to-transparent mx-auto my-8"></div>

    <div class="animate-fade-up-7 flex gap-4 justify-center flex-wrap">
      <a href="#servicios"
         class="bg-gradient-to-br from-gold to-gold-dark text-dark px-8 py-3.5 text-xs tracking-widest uppercase font-semibold font-montserrat no-underline hover:-translate-y-0.5 hover:shadow-[0_8px_30px_rgba(201,168,76,0.35)] transition-all">
        Ver servicios
      </a>
      <a href={WA_LINK} target="_blank"
         class="border border-soft/25 text-soft px-8 py-3.5 text-xs tracking-widest uppercase font-medium font-montserrat no-underline flex items-center gap-2 hover:border-gold hover:text-gold transition-all">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
        </svg>
        WhatsApp
      </a>
    </div>
  </div>
</section>
